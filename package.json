	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@trivago/prettier-plugin-sort-imports": "^5.2.2",
		"oxlint": "^1.56.0",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tailwindcss": "^4.2.2"
	},
	"prettier": {
		"semi": false,
		"singleQuote": true,
		"tabWidth": 4,
